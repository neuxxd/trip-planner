/* pages/map/map.wxss */

.container {
  position: relative;
  height: 100vh;
  width: 100vw;
}

/* 地图 */
.map {
  width: 100%;
  height: 100%;
}

/* 景点面板 */
.spots-panel {
  position: absolute;
  bottom: 100rpx;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease;
  max-height: 60vh;
}

.spots-panel.expanded {
  transform: translateY(-30vh);
}

.drag-bar {
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.drag-handle {
  width: 60rpx;
  height: 6rpx;
  background-color: #ddd;
  border-radius: 3rpx;
}

.spots-scroll {
  max-height: calc(60vh - 60rpx);
}

.panel-header {
  padding: 0 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.panel-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

/* 路线列表 */
.route-list {
  padding: 20rpx 30rpx;
}

.route-item {
  position: relative;
  display: flex;
  padding: 20rpx 0;
}

.route-marker {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.marker-num {
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}

.route-line {
  position: absolute;
  left: 24rpx;
  top: 68rpx;
  bottom: -20rpx;
  width: 2rpx;
  background-color: #e8e8e8;
}

.route-content {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  padding: 20rpx;
}

.route-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background-color: #eee;
  flex-shrink: 0;
}

.route-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.route-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.route-address {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.route-meta {
  display: flex;
  gap: 20rpx;
}

.route-time {
  font-size: 22rpx;
  color: #1890ff;
  background-color: #e6f7ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.route-distance {
  font-size: 22rpx;
  color: #666;
}

.route-nav {
  padding: 16rpx 28rpx;
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  border-radius: 28rpx;
  margin-left: 16rpx;
}

.nav-text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
}

/* 底部操作栏 */
.action-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  padding-bottom: env(safe-area-inset-bottom);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 40rpx;
}

.action-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.action-text {
  font-size: 22rpx;
  color: #666;
}
