/* pages/plan/plan.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 140rpx;
}

/* 行程概览 */
.summary-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  color: #fff;
}

.summary-header {
  margin-bottom: 30rpx;
}

.destination {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.days {
  font-size: 28rpx;
  opacity: 0.9;
}

.summary-stats {
  display: flex;
  justify-content: space-around;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.85;
}

/* 每日行程 */
.daily-plan-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.day-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.day-item {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.day-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.day-badge {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
  margin-right: 20rpx;
}

.day-date {
  font-size: 28rpx;
  color: #666;
}

/* 时间线 */
.spots-timeline {
  position: relative;
  padding-left: 30rpx;
}

.spots-timeline::before {
  content: '';
  position: absolute;
  left: 8rpx;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background-color: #e8e8e8;
}

.timeline-item {
  position: relative;
  margin-bottom: 30rpx;
}

.timeline-item:last-child {
  margin-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: -26rpx;
  top: 6rpx;
  width: 16rpx;
  height: 16rpx;
  background-color: #1890ff;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 2rpx #1890ff;
}

.timeline-content {
  margin-left: 20rpx;
}

.time-range {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.spot-card {
  display: flex;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  padding: 20rpx;
}

.spot-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background-color: #eee;
}

.spot-detail {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.spot-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.spot-duration {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.spot-tips {
  font-size: 22rpx;
  color: #1890ff;
}

/* 每日信息 */
.day-info {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.info-item {
  display: flex;
  margin-bottom: 16rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: #666;
  width: 140rpx;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

/* 费用明细 */
.cost-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.cost-list {
  display: flex;
  flex-direction: column;
}

.cost-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.cost-item:last-child {
  border-bottom: none;
}

.cost-item.total {
  padding-top: 30rpx;
  margin-top: 10rpx;
  border-top: 2rpx solid #f0f0f0;
}

.cost-label {
  font-size: 28rpx;
  color: #666;
}

.cost-item.total .cost-label {
  font-weight: 600;
  color: #333;
}

.cost-value {
  font-size: 28rpx;
  color: #333;
}

.cost-item.total .cost-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4d4f;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.action-btn.secondary {
  background-color: #f0f0f0;
  color: #666;
}

.action-btn.primary {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
}
