/* pages/spots/spots.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 搜索栏 */
.search-section {
  background-color: #fff;
  padding: 20rpx 30rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-input {
  flex: 1;
  height: 56rpx;
  font-size: 28rpx;
}

.search-btn {
  color: #1890ff;
  font-size: 28rpx;
  margin-left: 20rpx;
}

/* 景点列表 */
.spots-section {
  padding: 20rpx 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.spots-list {
  height: calc(100vh - 280rpx);
}

.spot-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
}

.spot-item.selected {
  border-color: #1890ff;
  background-color: #f0f7ff;
}

.spot-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #eee;
}

.spot-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.spot-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.spot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.spot-tag {
  padding: 6rpx 16rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #666;
}

.spot-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.spot-rating {
  font-size: 26rpx;
  color: #ff9500;
}

.spot-price {
  font-size: 26rpx;
  color: #ff4d4f;
  font-weight: 500;
}

.spot-checkbox {
  margin-left: 20rpx;
}

.checkbox-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  background-color: #fff;
}

.checkbox-icon.checked {
  background-color: #1890ff;
  border-color: #1890ff;
  position: relative;
}

.checkbox-icon.checked::after {
  content: '';
  position: absolute;
  left: 14rpx;
  top: 6rpx;
  width: 10rpx;
  height: 20rpx;
  border: 4rpx solid #fff;
  border-left: none;
  border-top: none;
  transform: rotate(45deg);
}

/* 加载状态 */
.loading-more, .no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #999;
}

/* 已选浮层 */
.selected-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.selected-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.selected-count {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.selected-clear {
  font-size: 26rpx;
  color: #999;
}

.selected-next {
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  font-size: 30rpx;
  border-radius: 40rpx;
}
