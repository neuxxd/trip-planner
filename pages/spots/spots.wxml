<!--pages/spots/spots.wxml-->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-section">
    <view class="search-bar">
      <input 
        class="search-input" 
        placeholder="搜索景点..." 
        value="{{keyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
      <view class="search-btn" bindtap="onSearch">搜索</view>
    </view>
  </view>

  <!-- 景点列表 -->
  <view class="spots-section">
    <view class="section-title">推荐景点</view>
    
    <scroll-view class="spots-list" scroll-y="true" bindscrolltolower="onLoadMore">
      <view 
        class="spot-item {{item.selected ? 'selected' : ''}}" 
        wx:for="{{spots}}" 
        wx:key="id"
        data-index="{{index}}"
        bindtap="onSelectSpot"
      >
        <image class="spot-image" src="{{item.image}}" mode="aspectFill"/>
        
        <view class="spot-info">
          <text class="spot-name">{{item.name}}</text>
          <view class="spot-tags">
            <text class="spot-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
          </view>
          <view class="spot-meta">
            <text class="spot-rating">⭐ {{item.rating}}</text>
            <text class="spot-price">¥{{item.price}}/人</text>
          </view>
        </view>
        
        <view class="spot-checkbox">
          <view class="checkbox-icon {{item.selected ? 'checked' : ''}}"></view>
        </view>
      </view>
      
      <!-- 加载更多 -->
      <view class="loading-more" wx:if="{{loading}}">加载中...</view>
      <view class="no-more" wx:if="{{noMore && spots.length > 0}}">没有更多了</view>
    </scroll-view>
  </view>

  <!-- 已选景点浮层 -->
  <view class="selected-bar" wx:if="{{selectedCount > 0}}">
    <view class="selected-info">
      <text class="selected-count">已选 {{selectedCount}} 个景点</text>
      <text class="selected-clear" bindtap="onClearSelected">清空</text>
    </view>
    <view class="selected-next" bindtap="onNext">下一步</view>
  </view>
</view>
